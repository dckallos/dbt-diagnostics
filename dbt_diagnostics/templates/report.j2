
======================================================================
  {{ "dbt Diagnostics" | bold_white }}
  {{ total }} result(s) | {{ errors }} error(s) | {{ fails }} fail(s) | {{ warns }} warn(s) | {{ skipped }} skipped
======================================================================
{% for group in report_groups %}

  ----------------------------------------------------------------------
  {{ "GROUP:" | bold_white }} {{ group.title }}
  ----------------------------------------------------------------------
{% for report in group.reports %}
{% if report.error_class == "test_failure" %}
  {{ "FAIL:" | bold_yellow }} {{ report.unique_id | bold }}
{% else %}
  {{ "ERROR:" | bold_red }} {{ report.unique_id | bold }}
{% endif %}
{% endfor %}
  {{ "Class:" | bold_white }} {{ group.error_class }}
  ======================================================================
{% if verbose %}
{% for report in group.reports %}
{% if report.has_findings %}
{% for finding in report.findings %}
{% include 'findings/' + report.error_class + '.j2' ignore missing %}
{% endfor %}
{% endif %}
{% endfor %}
{% else %}
{% set first_report = group.reports[0] %}
{% if first_report.has_findings %}
{% set finding = first_report.findings[0] %}
{% include 'findings/' + first_report.error_class + '.j2' ignore missing %}
{% if group.reports | length > 1 %}
  ({{ group.reports | length - 1 }} more similar result(s) -- use --verbose to expand)
{% endif %}
{% endif %}
{% endif %}

{% if group.combined_fix %}
  {{ "COMBINED FIX:" | bold_white }}
{% for line in group.combined_fix.splitlines() %}
    {{ line | green }}
{% endfor %}
{% endif %}
{% endfor %}
{% for report in ungrouped_reports %}

{% if report.error_class == "test_failure" %}
  {{ "FAIL:" | bold_yellow }} {{ report.unique_id | bold }}
  {{ "Class:" | bold_white }} {{ report.error_class }}
  ======================================================================
{% else %}
  {{ "ERROR:" | bold_red }} {{ report.unique_id | bold }}
  {{ "Class:" | bold_white }} {{ report.error_class }}
  ======================================================================
{% endif %}
{% if report.cascade_note %}
  {{ "CASCADE:" | bold_yellow }}
    {{ report.cascade_note | dim }}

{% endif %}
{% if not report.has_findings %}
  Could not classify. Raw message:
    {{ report.raw_message[:500] }}
{% else %}
{% for finding in report.findings %}
{% include 'findings/' + report.error_class + '.j2' ignore missing %}
{% endfor %}
{% endif %}
{% if report.diff %}
{% include 'findings/diff_section.j2' ignore missing %}
{% endif %}
{% endfor %}
{% if skipped_models %}

  ----------------------------------------------------------------------
{% if verbose %}
  SKIPPED ({{ skipped_models | length }} model(s) downstream of the above):
{% for model_id in skipped_models %}
    - {{ model_id }}
{% endfor %}
{% else %}
  SKIPPED (downstream of the above):
{% for name in skipped_summary.models[:5] %}
    - {{ name }}
{% endfor %}
{% if skipped_summary.models | length > 5 %}
    ... and {{ skipped_summary.models | length - 5 }} more model(s)
{% endif %}
{% if skipped_summary.test_count > 0 %}
    + {{ skipped_summary.test_count }} test(s) skipped (downstream)
{% endif %}
{% endif %}
{% endif %}
{% if warn_details %}

  ----------------------------------------------------------------------
  {{ "WARNINGS" | bold_yellow }} ({{ warns }}):
  ----------------------------------------------------------------------
{% for category, items in warn_by_category.items() %}
{% if category == "project_hygiene" %}
  {{ "Project hygiene" | dim }} ({{ items | length }} check(s) from dbt_project_evaluator):
{% else %}
  {{ "Data quality" | bold_white }} ({{ items | length }} check(s)):
{% endif %}
{% for w in items %}
    - {{ w.name }} ({{ w.failures }} result(s))
{% endfor %}
{% if category == "project_hygiene" %}
  {{ "Run: dbt test -s package:dbt_project_evaluator" | dim }}
{% endif %}
{% endfor %}
{% endif %}
