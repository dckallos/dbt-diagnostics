
  {{ "ROOT CAUSE:" | bold_white }}
    {{ "File:" | cyan }}       {{ finding.location.file_path }}
    {{ "Problem:" | cyan }}    {{ finding.summary }}

{% if finding.fix_suggestion %}
  {{ "FIX:" | bold_white }}
{% for line in finding.fix_suggestion.splitlines() %}
    {{ line | green }}
{% endfor %}

{% endif %}
{% if verbose %}
{% if finding.explanation %}
  {{ "EXPLANATION:" | bold_white }}
{% for line in finding.explanation.split('. ') %}
    {{ line | dim }}{{ '.' if not line.endswith('.') else '' }}
{% endfor %}
{% endif %}

{% if finding.session_params_to_check %}
  SESSION PARAMETERS TO VERIFY:
{% for param in finding.session_params_to_check %}
    SHOW PARAMETERS LIKE '{{ param }}' IN ACCOUNT;
{% endfor %}
{% endif %}
{% endif %}
