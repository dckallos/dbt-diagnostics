
  ROOT CAUSE:
    File:       {{ finding.location.file_path }}
{% if finding.location.line_number %}
    Line:       {{ finding.location.line_number }}
{% endif %}
    Problem:    {{ finding.summary }}

{% if finding.upstream_origin and not verbose %}
  NOTE: This identifier originates from upstream model {{ finding.upstream_origin.model_id | short_name }}.
        Use --verbose for full upstream trace.

{% endif %}
{% if finding.fix_suggestion %}
  FIX:
{% for line in finding.fix_suggestion.splitlines() %}
    {{ line }}
{% endfor %}

{% endif %}
{% if finding.enrichment and finding.enrichment.matched_error_message %}
  RAW ERROR (from Snowflake):
    {{ finding.enrichment.matched_error_message }}
{% if finding.enrichment.matched_error_code %}
    Error code: {{ finding.enrichment.matched_error_code }}
{% endif %}

{% endif %}
{% if verbose %}
{% if finding.upstream_origin %}
  UPSTREAM ORIGIN:
    This identifier is expected from: {{ finding.upstream_origin.model_id }}
{% if finding.upstream_origin.file_path %}
    Upstream file: {{ finding.upstream_origin.file_path }}
{% endif %}
    The column may have been renamed or removed in that upstream model.
{% endif %}

{% if finding.enrichment %}
{% if finding.enrichment.object_exists == true %}
  VERIFIED (live):
    Object EXISTS in Snowflake. This is likely a permissions issue, not a missing object.
{% elif finding.enrichment.object_exists == false %}
  VERIFIED (live):
    Object does NOT exist in Snowflake. The DDL has not been applied.
{% endif %}
{% if finding.enrichment.actual_columns %}
  ACTUAL COLUMNS (live):
{% for col in finding.enrichment.actual_columns[:10] %}
    {{ col.name }} ({{ col.data_type }})
{% endfor %}
{% if finding.enrichment.actual_columns | length > 10 %}
    ... and {{ finding.enrichment.actual_columns | length - 10 }} more
{% endif %}
{% endif %}
{% endif %}

{% if finding.explanation %}
  EXPLANATION:
{% for line in finding.explanation.split('. ') %}
    {{ line }}{{ '.' if not line.endswith('.') else '' }}
{% endfor %}
{% endif %}
{% endif %}
