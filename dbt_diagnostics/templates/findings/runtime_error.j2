{% if finding.fix_suggestion %}
  {{ "FIX:" | bold_white }}
{% for line in finding.fix_suggestion.splitlines() %}
    {{ line | green }}
{% endfor %}

{% endif %}
{% if finding.enrichment and finding.enrichment.matched_error_message %}
  RAW ERROR (from Snowflake):
    {{ finding.enrichment.matched_error_message }}
{% if finding.enrichment.matched_error_code %}
    Error code: {{ finding.enrichment.matched_error_code }}
{% endif %}

