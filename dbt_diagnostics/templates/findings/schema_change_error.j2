
  {{ "ROOT CAUSE:" | bold_white }}
    {{ "File:" | cyan }}       {{ finding.location.file_path }}
{% if finding.location.line_number %}
    {{ "Line:" | cyan }}       {{ finding.location.line_number }}
{% endif %}
    {{ "Problem:" | cyan }}    {{ finding.summary }}

{% if finding.upstream_origin and not verbose %}
  NOTE: Column expected from upstream model {{ finding.upstream_origin.model_id | short_name }}.
        Use --verbose for full upstream trace.

{% endif %}
{% if finding.compiled_snippet or finding.lineage_trail %}
{% set trace_target = finding.target_identifier if finding.target_identifier else "column" %}
{% include "findings/lineage_trace.j2" %}
{% endif %}
{% if finding.fix_suggestion %}
  {{ "FIX:" | bold_white }}
{% for line in finding.fix_suggestion.splitlines() %}
    {{ line | green }}
{% endfor %}

{% endif %}
{% if verbose %}
{% if finding.upstream_origin %}
  UPSTREAM ORIGIN:
    Expected from: {{ finding.upstream_origin.model_id }}
{% if finding.upstream_origin.file_path %}
    Upstream file: {{ finding.upstream_origin.file_path }}
{% endif %}
    The column may have been renamed or removed in that upstream model/source.
{% endif %}

{% if finding.explanation %}
  {{ "EXPLANATION:" | bold_white }}
{% for line in finding.explanation.split('. ') %}
    {{ line | dim }}{{ '.' if not line.endswith('.') else '' }}
{% endfor %}
{% endif %}
{% endif %}
